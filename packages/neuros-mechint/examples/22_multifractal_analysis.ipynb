    "# Generate fractional Brownian motion (monofractal)\n",
    "def generate_fbm(n, H):\n",
    "    \"\"\"\n",
    "    Generate fractional Brownian motion.\n",
    "    H < 0.5: Anti-persistent\n",
    "    H = 0.5: Brownian motion\n",
    "    H > 0.5: Persistent\n",
    "    \"\"\"\n",
    "    fgn = np.random.randn(n)\n",
    "    \n",
    "    # Apply power-law filter in Fourier domain\n",
    "    f = np.fft.rfftfreq(n)[1:]\n",
    "    spectrum = np.zeros(n//2 + 1)\n",
    "    spectrum[0] = 0\n",
    "    spectrum[1:] = f**(-H - 0.5)\n",
    "    \n",
    "    fgn_fft = np.fft.rfft(fgn)\n",
    "    fgn_fft *= np.sqrt(spectrum)\n",
    "    \n",
    "    fbm = np.fft.irfft(fgn_fft, n)\n",
    "    return np.cumsum(fbm)\n",
    "\n",
    "# Generate multifractal cascade\n",
    "def generate_multifractal_cascade(n):\n",
    "    \"\"\"\n",
    "    Generate multifractal signal via multiplicative cascade.\n",
    "    Creates heterogeneous scaling with multiple exponents.\n",
    "    \"\"\"\n",
    "    # Start with uniform signal\n",
    "    signal = np.ones(n)\n",
    "    \n",
    "    # Multiplicative cascade\n",
    "    scale = n\n",
    "    while scale > 2:\n",
    "        for i in range(0, n, scale):\n",
    "            if i + scale <= n:\n",
    "                # Split into two parts with random weights\n",
    "                w1 = np.random.uniform(0.2, 0.8)\n",
    "                w2 = 1 - w1\n",
    "                signal[i:i+scale//2] *= w1 * 2\n",
    "                signal[i+scale//2:i+scale] *= w2 * 2\n",
    "        scale //= 2\n",
    "    \n",
    "    # Cumulative sum for integrated process\n",
    "    return np.cumsum(signal - signal.mean())\n",
    "\n",
    "# Generate signals\n",
    "print(\"Generating test signals...\\n\")\n",
    "n = 8192  # Use power of 2 for efficiency\n",
    "H_persistent = 0.7\n",
    "\n",
    "monofractal = generate_fbm(n, H=H_persistent)\n",
    "multifractal = generate_multifractal_cascade(n)\n",
    "\n",
    "print(f\"Generated signals (n={n}):\")\n",
    "print(f\"  Monofractal: FBM with H={H_persistent}\")\n",
    "print(f\"  Multifractal: Multiplicative cascade\")\n",
    "print(f\"\\nSignal statistics:\")\n",
    "print(f\"  Monofractal: mean={monofractal.mean():.2f}, std={monofractal.std():.2f}\")\n",
    "print(f\"  Multifractal: mean={multifractal.mean():.2f}, std={multifractal.std():.2f}\")"
   ]
