    "## Part 6: Statistical Testing - Phase Shuffling\n",
    "\n",
    "**Test significance** by destroying multifractal structure via phase shuffling.\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Phase shuffling test\n",
    "print(\"Running phase shuffling statistical test...\\n\")\n",
    "\n",
    "# Phase shuffle NeuroFMx signal\n",
    "fft_signal = np.fft.fft(neurofmx_signal)\n",
    "phases = np.angle(fft_signal)\n",
    "shuffled_phases = np.random.permutation(phases)\n",
    "surrogate = np.fft.ifft(np.abs(fft_signal) * np.exp(1j * shuffled_phases)).real\n",
    "\n",
    "# Analyze surrogate\n",
    "print(\"Analyzing phase-shuffled surrogate...\")\n",
    "mfdfa_surrogate = MultifractalDetrendedFluctuationAnalysis(q_values=q_values, scales=scales)\n",
    "result_surrogate = mfdfa_surrogate.analyze(surrogate)\n",
    "\n",
    "h_surrogate = result_surrogate['hurst_exponents']\n",
    "width_h_surrogate = h_surrogate.max() - h_surrogate.min()\n",
    "\n",
    "# Statistical test\n",
    "print(f\"\\nPhase Shuffling Test Results:\")\n",
    "print(f\"  Original Δh: {width_h_neurofmx:.3f}\")\n",
    "print(f\"  Surrogate Δh: {width_h_surrogate:.3f}\")\n",
    "print(f\"  Ratio: {width_h_neurofmx / width_h_surrogate:.2f}x\")\n",
    "\n",
    "if width_h_neurofmx > 1.5 * width_h_surrogate:\n",
    "    print(f\"\\n✓ NeuroFMx is SIGNIFICANTLY multifractal\")\n",
    "    print(f\"  (>1.5x surrogate width)\")\n",
    "else:\n",
    "    print(f\"\\n⚠ Multifractality not statistically significant\")\n",
    "    print(f\"  (comparable to phase-shuffled surrogate)\")"
   ]
